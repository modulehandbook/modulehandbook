<div class="mb-3">
  <div class="row g-3">
    <div class="col">
      <%= render 'course_field', course: @course,
          field_name: :name, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>

    <div class="col">
      <div class="mb-3">
        <%= render 'course_field', course: @course,
            field_name: :ects, markdown: false,
            editing: editing, form: form, rows: 1 %>
      </div>
    </div>

    <div class="col">
      <%= render 'course_field', course: @course,
          field_name: :responsible_person, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :code, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>

  <div class="col">
    <%= render 'course_field', course: @course,
        field_name: :teacher, markdown: false,
        editing: editing, form: form, rows: 1 %>
  </div>

  <div class="col">
    <%= render 'course_field', course: @course, label: "Email",
        field_name: :responsible_person_mail, markdown: false,
        editing: editing, form: form, rows: 1 %>
  </div>
</div>

<div class="row g-3">
  <div class="col">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :lectureHrs, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>

  <div class="col">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :labHrs, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>

  <div class="col">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :tutorialHrs, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :semester_type, markdown: false,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>

  <div class="col">
    <div class="mb-3">
      <%= render "course_computed_field", 
          label: "Student workload", 
          computed_value: "#{@course.ects * 30} hrs", 
          markdown: false, editing: editing,
          editable: false, form: form, rows: 1 %>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col no_print_imi">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :room, markdown: true,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>

  <div class="col no_print_imi">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :specialization, markdown: true,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col no_print_imi">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :department, markdown: true,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>

  <div class="col no_print_imi">
    <div class="mb-3">
      <%= render 'course_field', course: @course,
          field_name: :head_of_department, markdown: true,
          editing: editing, form: form, rows: 1 %>
    </div>
  </div>
</div>

<% fields = [
      [:equipment, 3], [:mission, 3, "no_print_imi"], [:examination, 3, "no_print_imi"],
      [:objectives, 7], [:contents, 7],
      [:prerequisites, 3], [:literature, 7],
      [:methods, 7, "no_print_imi"], [:skills_knowledge_understanding, 7, "no_print_imi"],
      [:skills_intellectual, 3, "no_print_imi"], [:skills_practical, 3, "no_print_imi"],
      [:skills_general, 3, "no_print_imi"], [:comment, 3]
    ] %>

<% fields.each do |field_name, rows, css_classes| %>
  <div class="mb-3 <%= css_classes || "" %>">
    <%= render 'course_field', course: @course,
        field_name: field_name, markdown: true,
        editing: editing, form: form, rows: rows %>
  </div>
<% end %>
